APP_NAME=cours-reseaux
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

# Mail
MAIL_FROM=contact@cours-reseaux.fr
MAIL_TO=contact@cours-reseaux.fr

# Security
CSP_DEFAULT_SRC="'self' https:"
CSP_SCRIPT_SRC="'self' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com 'unsafe-inline'"
CSP_STYLE_SRC="'self' https://cdn.jsdelivr.net https://fonts.googleapis.com 'unsafe-inline'"
CSP_FONT_SRC=https://fonts.gstatic.com https://cdn.jsdelivr.net
CSP_IMG_SRC="'self' data: https://www.gravatar.com https://upload.wikimedia.org"

# Rate limiting
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60

# API
API_PUBLIC_TOKEN=82969263953921582058

# Paths
DB_WIKI_URL=https://cours-reseaux.fr/bts_sio/doku.php/start
